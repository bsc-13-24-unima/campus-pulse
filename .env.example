
# ============================================
# SERVER CONFIGURATION
# ============================================
PORT=3000
NODE_ENV=development
FRONTEND_URL=http://localhost:3001

# ============================================
# DATABASE CONFIGURATION (Oracle)
# ============================================
DB_HOST=localhost
DB_PORT=1521
DB_SID=auth_test_pdb
DB_USER=auth_test_user
DB_PASSWORD=user

# Alternative connection string format (if your backend uses this)
# DATABASE_URL=localhost:1521/auth_test_pdb

# ============================================
# JWT AUTHENTICATION
# ============================================
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=24h

# ============================================
# RATE LIMITING
# ============================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# CAMPUS CONFIGURATION
# ============================================
CAMPUS_EMAIL_DOMAIN=unima.ac.mw

# ============================================
# OPTIONAL: For testing with different users
# ============================================
# ADMIN_EMAIL=admin@unima.ac.mw
# ADMIN_PASSWORD=Admin123
# TEST_USER_EMAIL=student@unima.ac.mw
# TEST_USER_PASSWORD=Student123
